{
	"name": "@revealjs/react",
	"version": "0.1.2",
	"description": "React wrapper for reveal.js",
	"license": "MIT",
	"homepage": "https://revealjs.com/react",
	"author": {
		"name": "Hakim El Hattab",
		"email": "hakim.elhattab@gmail.com",
